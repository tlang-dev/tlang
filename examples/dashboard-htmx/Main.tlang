// ── Orders filter toolbar ─────────────────────────────────────────────────
//
// A compact row of native <select> controls that POST HTMX params to
// /api/orders, targeting #orders-tbody for seamless live filtering.

func renderOrdersFilterBar(): String {
    let statusOpts = "<option value=\"\">All statuses</option>\n" +
                     "<option value=\"paid\">Paid</option>\n" +
                     "<option value=\"pending\">Pending</option>\n" +
                     "<option value=\"processing\">Processing</option>\n" +
                     "<option value=\"refunded\">Refunded</option>\n"
    let rangeOpts  = "<option value=\"30d\">Last 30 days</option>\n" +
                     "<option value=\"7d\">Last 7 days</option>\n" +
                     "<option value=\"today\">Today</option>\n" +
                     "<option value=\"custom\">Custom range&hellip;</option>\n"
    let sortOpts   = "<option value=\"date_desc\">Newest first</option>\n" +
                     "<option value=\"date_asc\">Oldest first</option>\n" +
                     "<option value=\"amount_desc\">Highest amount</option>\n" +
                     "<option value=\"amount_asc\">Lowest amount</option>\n"

    let statusSel = generate_html(filterSelect("status", "Filter by status", statusOpts, "/api/orders", "#orders-tbody"))
    let rangeSel  = generate_html(filterSelect("range",  "Date range",       rangeOpts,  "/api/orders", "#orders-tbody"))
    let sortSel   = generate_html(filterSelect("sort",   "Sort orders",      sortOpts,   "/api/orders", "#orders-tbody"))

    let s = "<div class=\"orders-toolbar\">\n"
    let s = s + "  <span style=\"font-size:.75rem;font-weight:500;color:var(--text-muted)\">Filter:</span>\n"
    let s = s + statusSel
