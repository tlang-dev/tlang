    let s = s + "  <span class=\"orders-toolbar__count\">Showing 5 of 2,730 orders</span>\n"
    let s = s + "</div>\n"
    return s
}

// ── New Order slide-over ──────────────────────────────────────────────────
//
// A full-height panel that slides in from the right.  The form POSTs to
// /api/orders via HTMX and prepends the new row into #orders-tbody without
// a full page reload.  Opened/closed by openNewOrder() / closeNewOrder()
// in the inline script at the bottom of the page.

func renderNewOrderDialog(): String {
    let s = "<div class=\"slide-over-overlay\" id=\"new-order-overlay\" onclick=\"closeNewOrder()\"></div>\n"
    let s = s + "<div class=\"slide-over\" id=\"new-order-panel\"\n"
    let s = s + "     role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"new-order-title\">\n"
    let s = s + "  <div class=\"slide-over__header\">\n"
    let s = s + "    <h2 class=\"slide-over__title\" id=\"new-order-title\">Create New Order</h2>\n"
    let s = s + "    <button class=\"slide-over__close\" aria-label=\"Close panel\" onclick=\"closeNewOrder()\">&#215;</button>\n"
    let s = s + "  </div>\n"
    let s = s + "  <form class=\"slide-over__body\" id=\"new-order-form\"\n"
    let s = s + "        hx-post=\"/api/orders\"\n"
    let s = s + "        hx-target=\"#orders-tbody\"\n"
    let s = s + "        hx-swap=\"afterbegin\"\n"
    let s = s + "        hx-on::after-request=\"closeNewOrder()\">\n"

    let s = s + "    <p class=\"form-section-title\">Customer</p>\n"

    let s = s + "    <div class=\"form-group\">\n"
    let s = s + "      <label class=\"form-label form-label--req\" for=\"ord-customer\">Customer name</label>\n"
    let s = s + "      <input id=\"ord-customer\" name=\"customer\" type=\"text\" class=\"form-input\"\n"
    let s = s + "             placeholder=\"Jane Smith\" required autocomplete=\"off\"\n"
    let s = s + "             hx-get=\"/api/customers/search\" hx-trigger=\"input changed delay:250ms\"\n"
    let s = s + "             hx-target=\"#customer-suggestions\" hx-swap=\"innerHTML\"\n"
    let s = s + "             hx-include=\"[name='customer']\">\n"
    let s = s + "      <div id=\"customer-suggestions\"></div>\n"
    let s = s + "    </div>\n"

    let s = s + "    <div class=\"form-group\">\n"
    let s = s + "      <label class=\"form-label form-label--req\" for=\"ord-email\">Email address</label>\n"
    let s = s + "      <input id=\"ord-email\" name=\"email\" type=\"email\" class=\"form-input\"\n"
    let s = s + "             placeholder=\"jane@example.com\" required>\n"
    let s = s + "    </div>\n"

    let s = s + "    <hr class=\"form-divider\">\n"
    let s = s + "    <p class=\"form-section-title\">Order Details</p>\n"

    let s = s + "    <div class=\"form-group\">\n"
    let s = s + "      <label class=\"form-label form-label--req\" for=\"ord-plan\">Plan / Product</label>\n"
    let s = s + "      <select id=\"ord-plan\" name=\"plan\" class=\"form-select\" required>\n"
    let s = s + "        <option value=\"\">Select a plan&hellip;</option>\n"
    let s = s + "        <option value=\"nucleus-pro\">Nucleus Pro Plan &mdash; $299/mo</option>\n"
    let s = s + "        <option value=\"analytics-addon\">Analytics Add-on &mdash; $49/mo</option>\n"
    let s = s + "        <option value=\"team-seats\">Team Seats Bundle &mdash; $99/seat</option>\n"
    let s = s + "        <option value=\"starter\">Nucleus Starter &mdash; Free</option>\n"
    let s = s + "        <option value=\"enterprise\">Enterprise Support &mdash; Custom</option>\n"
    let s = s + "      </select>\n"
    let s = s + "    </div>\n"

    let s = s + "    <div class=\"form-row\">\n"
    let s = s + "      <div class=\"form-group\">\n"
    let s = s + "        <label class=\"form-label form-label--req\" for=\"ord-qty\">Quantity / Seats</label>\n"
    let s = s + "        <input id=\"ord-qty\" name=\"qty\" type=\"number\" class=\"form-input\" min=\"1\" value=\"1\" required>\n"
    let s = s + "      </div>\n"
    let s = s + "      <div class=\"form-group\">\n"
    let s = s + "        <label class=\"form-label form-label--req\" for=\"ord-amount\">Amount ($)</label>\n"
    let s = s + "        <input id=\"ord-amount\" name=\"amount\" type=\"number\" class=\"form-input\"\n"
    let s = s + "               min=\"0\" step=\"0.01\" placeholder=\"0.00\" required>\n"
    let s = s + "      </div>\n"
    let s = s + "    </div>\n"

    let s = s + "    <div class=\"form-row\">\n"
    let s = s + "      <div class=\"form-group\">\n"
    let s = s + "        <label class=\"form-label form-label--req\" for=\"ord-status\">Status</label>\n"
    let s = s + "        <select id=\"ord-status\" name=\"status\" class=\"form-select\" required>\n"
    let s = s + "          <option value=\"paid\">Paid</option>\n"
    let s = s + "          <option value=\"pending\" selected>Pending</option>\n"
    let s = s + "          <option value=\"processing\">Processing</option>\n"
    let s = s + "        </select>\n"
    let s = s + "      </div>\n"
    let s = s + "      <div class=\"form-group\">\n"
    let s = s + "        <label class=\"form-label form-label--req\" for=\"ord-date\">Order date</label>\n"
    let s = s + "        <input id=\"ord-date\" name=\"date\" type=\"date\" class=\"form-input\" required>\n"
    let s = s + "      </div>\n"
    let s = s + "    </div>\n"

    let s = s + "    <div class=\"form-group\">\n"
    let s = s + "      <label class=\"form-label\" for=\"ord-notes\">\n"
    let s = s + "        Notes <span style=\"font-weight:400;color:var(--text-muted)\">(optional)</span>\n"
    let s = s + "      </label>\n"
    let s = s + "      <textarea id=\"ord-notes\" name=\"notes\" class=\"form-input\"\n"
    let s = s + "                rows=\"3\" style=\"resize:vertical\"></textarea>\n"
    let s = s + "    </div>\n"

    let s = s + "  </form>\n"
    let s = s + "  <div class=\"slide-over__footer\">\n"
    let s = s + "    <button type=\"button\" class=\"ui-btn ui-btn--ghost\" onclick=\"closeNewOrder()\">Cancel</button>\n"
    let s = s + "    <button type=\"submit\" form=\"new-order-form\" class=\"ui-btn ui-btn--primary\">&#10003; Create Order</button>\n"
    let s = s + "  </div>\n"
    let s = s + "</div>\n"
    return s
}

// ── Customers stats row ───────────────────────────────────────────────────
//
// Four mini-stat cards giving a quick customer health snapshot.
// HTMX polls /api/customers/stats every 60 s for live updates.

func renderCustomersRow(): String {
    let d1 = renderDelta("+3.1%",  "up")
    let d2 = renderDelta("+8.2%",  "up")
    let d3 = renderDelta("-0.9%",  "down")
    let d4 = renderDelta("+12.4%", "up")

    let s1 = generate_html(customerMiniStat("&#128100;", "Total Customers",   "131,842", d1, "All-time registered"))
    let s2 = generate_html(customerMiniStat("&#128293;", "Active This Month",  "48,291", d2, "Logged in &ge;&thinsp;once"))
    let s3 = generate_html(customerMiniStat("&#128683;", "Churned (30 d)",      "1,204", d3, "Cancelled subscription"))
    let s4 = generate_html(customerMiniStat("&#10024;",  "Net New (30 d)",       "4,891", d4, "Signups minus churn"))

    let s = "<div class=\"mini-stat-row\"\n"
    let s = s + "     hx-get=\"/api/customers/stats\" hx-trigger=\"every 60s\" hx-swap=\"outerHTML\">\n"
    let s = s + s1 + s2 + s3 + s4
    let s = s + "</div>\n"
    return s
}



// ── Acquisition funnel ────────────────────────────────────────────────────
//
// Horizontal proportional bars for each traffic / acquisition channel.
// The list targets #acq-list via HTMX so the backend can push live updates.

func renderAcquisitionFunnel(): String {
    let ch1 = generate_html(acquisitionBar("Organic Search",    "54,210", "41", "seg-indigo"))
    let ch2 = generate_html(acquisitionBar("Direct / Referral", "28,440", "22", "seg-emerald"))
    let ch3 = generate_html(acquisitionBar("Paid Ads",          "19,820", "15", "seg-amber"))
    let ch4 = generate_html(acquisitionBar("Social Media",      "15,600", "12", "seg-sky"))
    let ch5 = generate_html(acquisitionBar("Email Campaign",    "13,772", "10", "seg-purple"))

    let s = "<div class=\"card\">\n"
    let s = s + "  <div class=\"card-header\">\n"
    let s = s + "    <div>\n"
    let s = s + "      <p class=\"card-title\">Acquisition Channels</p>\n"
    let s = s + "      <p class=\"card-subtitle\">Traffic sources &mdash; Jun 2025</p>\n"
    let s = s + "    </div>\n"
    let s = s + "    <button class=\"ui-btn ui-btn--ghost ui-btn--sm\"\n"
    let s = s + "            hx-get=\"/api/acquisition\" hx-target=\"#acq-list\"\n"
    let s = s + "            hx-swap=\"innerHTML\">Refresh</button>\n"
    let s = s + "  </div>\n"
    let s = s + "  <div class=\"segment-list\" id=\"acq-list\"\n"
    let s = s + "       hx-get=\"/api/acquisition\" hx-trigger=\"load\"\n"
    let s = s + "       hx-swap=\"innerHTML\">\n"
    let s = s + ch1 + ch2 + ch3 + ch4 + ch5
    let s = s + "  </div>\n"
    let s = s + "</div>\n"
    return s
}



// ── Page header ───────────────────────────────────────────────────────────

func renderPageHeader(): String {
    let s = "<div class=\"page-header\">\n"
    let s = s + "  <div>\n"
    let s = s + "    <h1 class=\"page-title\">Dashboard</h1>\n"
    let s = s + "    <p class=\"page-subtitle\">Welcome back, Admin. Here&rsquo;s what&rsquo;s happening today.</p>\n"
    let s = s + "  </div>\n"
    let s = s + "</div>\n"
    return s
}

// ── Main ──────────────────────────────────────────────────────────────────

func main(): String {
    let header   = doNotEditHeader()
    let open     = pageOpen()
    let sidebar  = renderSidebar()
    let topbar   = renderTopbar()
    let alert    = renderAlert()
    let pageHead = renderPageHeader()
    let kpis     = renderKpiSection()

    // Row 1 — Revenue chart (3 cols) + Recent orders table (7 cols)
    let chartAndOrders = "<div class=\"dash-row dash-row--3-7\" style=\"margin-bottom:1.5rem\">\n" +
                         renderRevenueChart() +
                         renderOrdersTable() +
                         "</div>\n"

    // Row 2 — Monthly goals (5 cols) + Top products (5 cols)
    let goalsAndProducts = "<div class=\"dash-row dash-row--5-5\" style=\"margin-bottom:1.5rem\">\n" +
                           renderGoalsSection() +
                           renderTopProducts() +
                           "</div>\n"

    // Customer stats mini-cards
    let customers = renderCustomersRow()

    // Row 3 — Acquisition funnel (4 cols) + Activity feed (6 cols)
    let acqAndActivity = "<div class=\"dash-row dash-row--4-6\" style=\"margin-bottom:1.5rem\">\n" +
                         renderAcquisitionFunnel() +
                         renderActivityFeed() +
                         "</div>\n"

    // Slide-over dialog — rendered outside the main scroll flow
    let dialog = renderNewOrderDialog()

    let main = "<div id=\"dash-main\" class=\"dash-main\">\n"
    let main = main + topbar
    let main = main + "<main class=\"dash-content\" id=\"main-content\">\n"
    let main = main + alert
    let main = main + pageHead
    let main = main + kpis
    let main = main + chartAndOrders
    let main = main + goalsAndProducts
    let main = main + customers
    let main = main + acqAndActivity
    let main = main + "</main>\n"
    let main = main + "</div>\n"
    let main = main + dialog

    let close = pageClose()
    let page  = header + open + sidebar + main + close

    TLang.File.write("output/index.html", page, true)
    TLang.Terminal.println("Generated: output/index.html")
    return "done"
}


