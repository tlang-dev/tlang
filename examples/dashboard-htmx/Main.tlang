// ── KPI cards ─────────────────────────────────────────────────────────────

// renderDelta — renders a coloured delta badge using the deltaBadge template.
func renderDelta(text: String, direction: String): String {
    let arrow = ""
    if (TLang.String.equals(direction, "up"))   { let arrow = "↑" }
    if (TLang.String.equals(direction, "down")) { let arrow = "↓" }
    return generate_html(deltaBadge(text, "delta--" + direction, arrow))
}

// renderSparkline — renders a .sparkline container whose bars are built
// via the sparklineBar template, one per space-separated value in `values`.
func renderSparkline(values: String, color: String): String {
    let parts = TLang.String.split(values, " ")
    let bars  = ""
    for (v in parts) {
        let bars = bars + generate_html(sparklineBar(v, color, v))
    }
    return "<div class=\"sparkline\" aria-hidden=\"true\">\n" + bars + "</div>\n"
}


func renderKpiSection(): String {
    let d1 = renderDelta("+14.5%", "up")
    let d2 = renderDelta("+8.2%",  "up")
    let d3 = renderDelta("+23.1%", "up")
    let d4 = renderDelta("-1.4%",  "down")

    let sp1 = renderSparkline("40 55 62 48 70 58 75 82 68 90 78 95", "var(--color-indigo)")
    let sp2 = renderSparkline("30 42 38 55 60 48 65 70 58 78 72 88", "var(--color-emerald)")
    let sp3 = renderSparkline("50 38 65 42 58 72 55 80 68 76 85 91", "var(--color-amber)")
    let sp4 = renderSparkline("42 45 40 38 43 41 36 38 35 37 33 34", "var(--color-rose)")

    let c1 = generate_html(kpiCard("kpi-revenue",    "&#128176;", "kpi-icon--indigo",
                                               "Total Revenue",   "$124,592", d1, "vs last month",
                                               sp1, "/api/kpi/revenue", "every 60s"))

    let c2 = generate_html(kpiCard("kpi-users",      "&#128100;", "kpi-icon--emerald",
                                               "Active Users",    "48,291",   d2, "vs last month",
                                               sp2, "/api/kpi/users",  "every 60s"))

    let c3 = generate_html(kpiCard("kpi-orders",     "&#128230;", "kpi-icon--amber",
                                               "New Orders",      "2,730",    d3, "vs last month",
                                               sp3, "/api/kpi/orders", "every 60s"))

    let c4 = generate_html(kpiCard("kpi-conversion", "&#128200;", "kpi-icon--rose",
                                               "Conversion Rate", "3.24%",    d4, "vs last month",
                                               sp4, "/api/kpi/conversion", "every 60s"))

    let s = "<section aria-labelledby=\"kpi-heading\">\n"
    let s = s + "  <h2 id=\"kpi-heading\" class=\"ui-sr-only\">Key Performance Indicators</h2>\n"
    let s = s + "  <div class=\"kpi-grid\">\n"
    let s = s + c1 + c2 + c3 + c4
    let s = s + "  </div>\n"
    let s = s + "</section>\n"
    return s
}

// ── Revenue chart ─────────────────────────────────────────────────────────

func renderRevenueChart(): String {
    let s = "<div class=\"card\" id=\"revenue-chart\">\n"
    let s = s + "  <div class=\"card-header\">\n"
    let s = s + "    <div>\n"
    let s = s + "      <p class=\"card-title\">Revenue Overview</p>\n"
    let s = s + "      <p class=\"card-subtitle\">Monthly comparison &mdash; current vs previous year</p>\n"
    let s = s + "    </div>\n"
    let s = s + "    <div style=\"display:flex;gap:.5rem;\">\n"
    let s = s + renderPeriodTabs()
    let s = s + "    </div>\n"
    let s = s + "  </div>\n"
    let s = s + "  <div class=\"chart-area\">\n"
    let s = s + "    <div class=\"chart-header\">\n"
    let s = s + "      <div>\n"
    let s = s + "        <p class=\"chart-label\">Total this period</p>\n"
    let s = s + "        <p class=\"chart-value\">$124,592</p>\n"
    let s = s + "      </div>\n"
    let s = s + "      <span class=\"delta delta--up\" style=\"margin-bottom:.4rem\">&#8593; +14.5%</span>\n"
    let s = s + "    </div>\n"
    let s = s + renderBarChart()
    let s = s + "    <div class=\"chart-legend\">\n"
    let s = s + "      <div class=\"chart-legend-item\"><span class=\"chart-legend-dot\" style=\"background:var(--color-indigo)\"></span>2025</div>\n"
    let s = s + "      <div class=\"chart-legend-item\"><span class=\"chart-legend-dot\" style=\"background:#e0e7ff\"></span>2024</div>\n"
    let s = s + "    </div>\n"
    let s = s + "  </div>\n"
    let s = s + "</div>\n"
    return s
}

func renderPeriodTabs(): String {
    let s = "<button class=\"ui-btn ui-btn--primary ui-btn--sm\" aria-pressed=\"true\">6M</button>\n"
    let s = s + "<button class=\"ui-btn ui-btn--ghost ui-btn--sm\" aria-pressed=\"false\">1Y</button>\n"
    let s = s + "<button class=\"ui-btn ui-btn--ghost ui-btn--sm\" aria-pressed=\"false\">All</button>\n"
    return s
}

func renderBarChart(): String {
    let current = "55 62 48 70 58 75 82 68 90 78 95 88"
    let prev    = "40 52 45 60 50 65 70 58 78 65 82 76"
    let months  = "Jan Feb Mar Apr May Jun Jul Aug Sep Oct Nov Dec"
    let s = "<div class=\"chart-bars\" role=\"img\" aria-label=\"Revenue bar chart\">\n"
    let s = s + renderChartBarGroups(current, prev, months)
    let s = s + "</div>\n"
    return s
}

func renderChartBarGroups(current: String, prev: String, months: String): String {
    let cParts = TLang.String.split(current, " ")
    let pParts = TLang.String.split(prev, " ")
    let mParts = TLang.String.split(months, " ")
    let out = ""
    let idx = 0
    for (c in cParts) {
        let p     = TLang.List.get(pParts, idx)
        let month = TLang.List.get(mParts, idx)
        let out = out + generate_html(chartBarGroup(
            month, c, p,
            "2025 " + month + ": $" + c + "k",
            "2024 " + month + ": $" + p + "k"
        ))
        let idx = idx + 1
    }
    return out
}

